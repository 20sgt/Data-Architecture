GCP_PROJECT_ID=corn-off-the-cobb
GCP_BUCKET_NAME=podcasts-audio-files
GCP_SERVICE_ACCOUNT_KEY=

# Optional: seconds between checks when running with --watch (default 21600 = 6 hours)
POLL_INTERVAL_SECONDS=86400 #21600=6 hours, 24 hours

# Optional: Google Speech-to-Text language code
TRANSCRIPTION_LANGUAGE_CODE=en-US
