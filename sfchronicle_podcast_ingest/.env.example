GCP_PROJECT_ID=corn-off-the-cobb
GCP_BUCKET_NAME=podcasts-audio-files
GCP_SERVICE_ACCOUNT_KEY= # uploaded to github, NEED TO REPLACE

# Optional: seconds between checks when running with --watch (default 21600 = 6 hours)
POLL_INTERVAL_SECONDS=86400 #21600=6 hours, 24 hours

# Local Whisper settings (free; no Google Speech-to-Text charges)
TRANSCRIPTION_LANGUAGE_CODE=en
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# New Whisper-only transcript prefix (never write to podcasts/transcripts)
TRANSCRIPT_PREFIX=podcasts/transcripts_whisper

# Silver layer (free: local SQLite + GCS JSONL, no BigQuery)
ENRICHMENT_PREFIX=podcasts/enrichment
SILVER_PREFIX=podcasts/silver
# SILVER_SQLITE_PATH=data/podcast_silver.sqlite
# REPRESENTATIVES_PATH=data/representatives.json

