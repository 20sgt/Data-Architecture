# CONNECTION SETTINGS TEMPLATE — copy this to a real profiles.yml, then fill it in.
#
# This file tells dbt how to reach your Databricks workspace. The REAL version
# holds a secret access token, so it must NEVER be committed to git. Two options:
#   1. Save the real file at ~/.dbt/profiles.yml  (dbt's default location), or
#   2. Keep it here as dbt/profiles.yml and run dbt with:  DBT_PROFILES_DIR=dbt
# Either way, dbt/profiles.yml is already in .gitignore.
#
# The three values below come from your Databricks SQL warehouse:
#   Databricks UI -> SQL Warehouses -> (your warehouse) -> Connection details.
# The token is a personal access token: User Settings -> Developer -> Access tokens.
#
# We read the secrets from environment variables so no secret is written in this
# file. Set them in your shell before running dbt, e.g.:
#   export DBT_DATABRICKS_HOST="dbc-xxxxxxxx-xxxx.cloud.databricks.com"
#   export DBT_DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/abc123def456"
#   export DBT_DATABRICKS_TOKEN="dapi........................"
#
# NOTE: when this project runs as a dbt task inside a Databricks Job, Databricks
# supplies the connection itself — this file is mainly for running dbt from your
# own laptop while developing.

sf_legislation:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: corn_off_the_cob   # our Unity Catalog catalog (top-level container)
      schema: gold           # default schema, used only if a model doesn't set its own
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      threads: 4             # how many models dbt may build at once
