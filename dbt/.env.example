# Copy this to dbt/.env (which is gitignored) and fill in your values, then run
# `source dbt/.env` once per terminal session before using dbt.
#
#   cp dbt/.env.example dbt/.env
#   # edit dbt/.env with your real values
#   source dbt/.env
#
# The .env file holds your secret token, so it must never be committed.

# --- Databricks connection (from your SQL warehouse's Connection details) ---
export DBT_DATABRICKS_HOST="8259559357598229.9.gcp.databricks.com"
export DBT_DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/aa8398aa70d15ec5"
export DBT_DATABRICKS_TOKEN="dapi........................"   # <- your secret token

# --- Tell dbt where the profiles.yml lives (so you can run dbt from anywhere) ---
export DBT_PROFILES_DIR="$(git rev-parse --show-toplevel)/dbt"

# --- Fix for the macOS/Python certificate issue (points Python at certifi) ---
# If these paths are ever empty, run:  pip install --upgrade certifi
export SSL_CERT_FILE="$(python -c 'import certifi; print(certifi.where())')"
export REQUESTS_CA_BUNDLE="$SSL_CERT_FILE"
